Instance.new("UIListLayout", Container).Padding = UDim.new(0, 12)

-- // FUNCTIONS (Toggle & Vis Check)
local function AddToggle(name, callback)
    local Frame = Instance.new("Frame", Container)
    Frame.Size = UDim2.new(1, 0, 0, 45); Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25); Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)
    local Lbl = Instance.new("TextLabel", Frame); Lbl.Text = name; Lbl.Size = UDim2.new(1, -60, 1, 0); Lbl.Position = UDim2.new(0, 12, 0, 0); Lbl.BackgroundTransparency = 1; Lbl.TextColor3 = Color3.fromRGB(200, 200, 200); Lbl.Font = Enum.Font.Gotham; Lbl.TextSize = 13; Lbl.TextXAlignment = Enum.TextXAlignment.Left
    local Sw = Instance.new("TextButton", Frame); Sw.Size = UDim2.new(0, 36, 0, 18); Sw.Position = UDim2.new(1, -45, 0.5, -9); Sw.BackgroundColor3 = Color3.fromRGB(50, 50, 50); Sw.Text = ""
    local Knob = Instance.new("Frame", Sw); Knob.Size = UDim2.new(0, 14, 0, 14); Knob.Position = UDim2.new(0, 2, 0.5, -7); Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
    local active = false
    Sw.MouseButton1Click:Connect(function()
        active = not active; callback(active)
        TweenService:Create(Knob, TweenInfo.new(0.2), {Position = active and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
        TweenService:Create(Sw, TweenInfo.new(0.2), {BackgroundColor3 = active and Settings.ThemeColor or Color3.fromRGB(50, 50, 50)}):Play()
    end)
end

local function IsVisible(part)
    local params = RaycastParams.new(); params.FilterDescendantsInstances = {LocalPlayer.Character, part.Parent}; params.FilterType = Enum.RaycastFilterType.Exclude
    local res = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * (part.Position - Camera.CFrame.Position).Magnitude, params)
    return res == nil
end

-- // MAIN LOOP
RunService.RenderStepped:Connect(function(dt)
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    -- Update Visual FOV Circle & Crosshair
    FOVCircle.Visible = Settings.ShowFOV; FOVCircle.Position = center; FOVCircle.Radius = Settings.FOVSize; FOVCircle.Color = Settings.ThemeColor
    CrosshairVertical.Visible = Settings.ShowCrosshair; CrosshairHorizontal.Visible = Settings.ShowCrosshair
    CrosshairVertical.Color = Settings.ThemeColor; CrosshairHorizontal.Color = Settings.ThemeColor
    CrosshairVertical.From = center - Vector2.new(0, 8); CrosshairVertical.To = center + Vector2.new(0, 8)
    CrosshairHorizontal.From = center - Vector2.new(8, 0); CrosshairHorizontal.To = center + Vector2.new(8, 0)

    -- Aim Assist Logic (Hanya target di dalam FOV)
    if Settings.AimAssist then
        local target, dist = nil, Settings.FOVSize
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") and p.Character.Humanoid.Health > 0 then
                local head = p.Character.Head; local pos, on = Camera:WorldToViewportPoint(head.Position)
                if on and IsVisible(head) then
                    local mag = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if mag < dist then target = head; dist = mag end
                end
            end
        end
        if target then
            local alpha = math.clamp(Settings.Smoothness * dt * 60, 0, 1)
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), alpha)
        end
    end

    -- Full ESP Loop
    for p, d in pairs(ESP_Cache) do
        if Settings.FullESP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local hrp = p.Character.HumanoidRootPart; local pos, vis = Camera:WorldToViewportPoint(hrp.Position)
            if vis then
                local h = math.abs(Camera:WorldToViewportPoint(p.Character.Head.Position + Vector3.new(0, 0.5, 0)).Y - Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0)).Y); local w = h * 0.6
                d.Tracer.Visible = true; d.Tracer.From = Vector2.new(center.X, Camera.ViewportSize.Y); d.Tracer.To = Vector2.new(pos.X, pos.Y + h/2); d.Tracer.Color = Settings.ThemeColor
                d.Box.Visible = true; d.Box.Filled = false; d.Box.Size = Vector2.new(w, h); d.Box.Position = Vector2.new(pos.X - w/2, pos.Y - h/2); d.Box.Color = Settings.ThemeColor
                d.Label.Visible = true; d.Label.Position = Vector2.new(pos.X, pos.Y - h/2 - 15); d.Label.Text = p.Name .. " [" .. math.floor(p.Character.Humanoid.Health) .. "%]"; d.Label.Color = Color3.new(1,1,1)
            else d.Tracer.Visible = false; d.Box.Visible = false; d.Label.Visible = false end
        else d.Tracer.Visible = false; d.Box.Visible = false; d.Label.Visible = false end
    end
end)

-- Player ESP Setup
local function AddESP(p)
    ESP_Cache[p] = {Tracer = Drawing.new("Line"), Box = Drawing.new("Square"), Label = Drawing.new("Text")}
    ESP_Cache[p].Tracer.Thickness = 1; ESP_Cache[p].Box.Thickness = 1.5; ESP_Cache[p].Box.Filled = false; ESP_Cache[p].Label.Size = 14; ESP_Cache[p].Label.Center = true; ESP_Cache[p].Label.Outline = true; ESP_Cache[p].Label.Font = 2
end
for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then AddESP(p) end end
Players.PlayerAdded:Connect(function(p) AddESP(p) end)
Players.PlayerRemoving:Connect(function(p) if ESP_Cache[p] then for _,o in pairs(ESP_Cache[p]) do o:Remove() end ESP_Cache[p]=nil end end)

-- UI Buttons
AddToggle("AIMBOT", function(v) Settings.AimAssist = v end)
AddToggle("FOV CIRCLE", function(v) Settings.ShowFOV = v end)
AddToggle("FULL ESP", function(v) Settings.FullESP = v end)
AddToggle("SHOW CROSSHAIR (+)", function(v) Settings.ShowCrosshair = v end)

