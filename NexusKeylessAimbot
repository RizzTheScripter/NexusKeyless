FOVCircle.Thickness = 1 -- Garis lebih tipis agar clean
FOVCircle.NumSides = 100 -- Sangat bulat, tidak patah-patah
FOVCircle.Filled = false
FOVCircle.Transparency = 0.5 -- Sedikit transparan agar premium
FOVCircle.Visible = false

-- Setup Center Crosshair (+)
CrosshairVertical.Thickness = 2; CrosshairVertical.Transparency = 1; CrosshairVertical.Visible = true
CrosshairHorizontal.Thickness = 2; CrosshairHorizontal.Transparency = 1; CrosshairHorizontal.Visible = true

-- // UI SETUP
