Title.Text = "NEXUS ECO"; Title.Size = UDim2.new(1, -70, 0, 60); Title.Position = UDim2.new(0, 65, 0, 0); Title.BackgroundTransparency = 1; Title.TextColor3 = Color3.fromRGB(255, 255, 255); Title.Font = Enum.Font.GothamBold; Title.TextSize = 18; Title.TextXAlignment = Enum.TextXAlignment.Left

