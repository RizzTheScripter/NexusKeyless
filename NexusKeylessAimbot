local Camera = workspace.CurrentCamera

-- // SETTINGS
local Settings = {
    AimAssist = false,
    FullESP = false,
    ShowFOV = false,
    ShowCrosshair = true,
    FOVSize = 150,
    Smoothness = 0.15,
    ThemeColor = Color3.fromRGB(0, 255, 127),
}

-- // DRAWING OBJECTS
